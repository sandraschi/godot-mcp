{
  "manifest_version": "0.3",
  "name": "godot-mcp",
  "version": "0.3.0",
  "description": "Godot 4 game engine control via MCP — 49 tools: engine control, game builder, asset import, itch.io/Steam shipping, fleet pipeline",
  "author": { "name": "Sandra Schipal", "url": "https://github.com/sandraschi" },
  "repository": { "type": "git", "url": "https://github.com/sandraschi/godot-mcp.git" },
  "homepage": "https://github.com/sandraschi/godot-mcp",
  "license": "Apache 2.0",
  "keywords": ["mcp", "godot", "game-engine", "game-development", "fastmcp"],
  "server": {
    "type": "python",
    "entry_point": "src/godot_mcp/server.py",
    "mcp_config": {
      "command": "python",
      "args": ["-m", "godot_mcp"],
      "env": { "PYTHONPATH": "${__dirname}/src", "PYTHONUNBUFFERED": "1" }
    }
  }
}
