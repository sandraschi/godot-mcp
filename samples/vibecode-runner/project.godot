; Engine configuration for Vibecoder Runner
[application]
config/name="Vibecoder Runner"
config/description="A 2D side-scrolling runner where you fight AI bugs as a vibecoder"
run/main_scene="res://MainScene.tscn"
config/icon="res://icon.svg"

[display]
window/size/viewport_width=1024
window/size/viewport_height=600
window/size/mode=2
window/dpi/allow_hidpi=true

[rendering]
renderer/rendering_method=gl_compatibility
environment/defaults/default_clear_color=Color(0.05, 0.05, 0.08, 1)
