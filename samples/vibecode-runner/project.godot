; Engine configuration file.
; VibeCode Runner — vibecoding-themed endless side-scroller

config_version=5

[application]

config/name="VibeCode Runner"
config/description="Jump over VS Code, Windsurf, and Cursor. Dodge PowerShell pipes, agent loops, and leaked API tokens. Ship the vibe or get rate-limited."
config/tags=PackedStringArray("2d", "platformer", "vibecoding", "godot-mcp")
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.4")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[input]

