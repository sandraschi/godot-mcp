"{\"manifest_version\": \"0.2\", \"name\": \"godot-mcp\", \"version\": \"0.3.0\", \"description\": \"Godot MCP server — Godot 4.x engine control via TCP bridge, STL/GLB/OBJ import, GPU particles, animation, HTML5 export, itch.io/Steam publishing, AI game builder pipeline, artifact depot, and cross-server MCP bridge\", \"author\": {\"name\": \"sandraschi\"}, \"icon\": \"mcpb/assets/icon.png\", \"server\": {\"type\": \"python\", \"entry_point\": \"run_server.py\", \"mcp_config\": {\"command\": \"uv\", \"args\": [\"run\", \"--directory\", \"${__dirname}\", \"run_server.py\"], \"env\": {\"PYTHONPATH\": \"${__dirname}/src\", \"PYTHONUNBUFFERED\": \"1\"}}}, \"tools\": [{\"name\": \"godot_status\", \"description\": \"Query Godot engine for version, FPS, and node count\"}, {\"name\": \"godot_read_scene_tree\", \"description\": \"Dump full scene hierarchy as nested JSON\"}, {\"name\": \"godot_set_config\", \"description\": \"Write a key=value to project.godot config\"}, {\"name\": \"godot_headless_verify\", \"description\": \"Check if Godot is in headless mode\"}, {\"name\": \"godot_create_camera\", \"description\": \"Create Camera3D with orbit controls\"}, {\"name\": \"godot_add_light\", \"description\": \"Add directional, ambient, or omni light\"}, {\"name\": \"godot_set_material\", \"description\": \"Assign StandardMaterial3D to a mesh node\"}, {\"name\": \"godot_import_stl\", \"description\": \"Import binary STL mesh as MeshInstance3D\"}, {\"name\": \"godot_import_glb\", \"description\": \"Import GLB/GLTF model via GLTFDocument\"}, {\"name\": \"godot_import_obj\", \"description\": \"Import Wavefront OBJ with MTL support\"}, {\"name\": \"godot_play_animation\", \"description\": \"Play or list animations on a GLB AnimationPlayer\"}, {\"name\": \"godot_load_velocity_field\", \"description\": \"Load CSV velocity field into scene\"}, {\"name\": \"godot_spawn_particles\", \"description\": \"Create GPUParticles3D system\"}, {\"name\": \"godot_animate_streamlines\", \"descriptio