 \"generate_game_worlds\", \"description\": \"Generate Marble worlds via World Labs\"}, {\"name\": \"compose_game_scene\", \"description\": \"Assemble Godot scene from game plan\"}, {\"name\": \"generate_game_logic\", \"description\": \"Generate GDScript for game mechanics\"}, {\"name\": \"export_and_ship\", \"description\": \"Export and ship game to itch.io\"}, {\"name\": \"build_game\", \"description\": \"End-to-end game build from concept\"}, {\"name\": \"artifact_list\", \"description\": \"List artifacts in local depot\"}, {\"name\": \"artifact_search\", \"description\": \"Search artifacts by name, description, tags\"}, {\"name\": \"artifact_get\", \"description\": \"Get artifact details by ID\"}, {\"name\": \"artifact_register\", \"description\": \"Register new artifact in depot\"}, {\"name\": \"artifact_delete\", \"description\": \"Delete artifact from depot\"}, {\"name\": \"prefab_list\", \"description\": \"List prefab templates\"}, {\"name\": \"prefab_apply\", \"description\": \"Apply prefab template tool sequence\"}, {\"name\": \"prompt_list\", \"description\": \"List prompt templates\"}, {\"name\": \"prompt_execute\", \"description\": \"Execute prompt template with LLM\"}, {\"name\": \"ai_describe_artifact\", \"description\": \"AI generate artifact description\"}, {\"name\": \"ai_generate_gdscript\", \"description\": \"Generate GDScript from spec\"}, {\"name\": \"workflow_list\", \"description\": \"List built-in agentic workflows\"}, {\"name\": \"workflow_run\", \"description\": \"Run multi-step agentic workflow\"}, {\"name\": \"bridge_connect\", \"description\": \"Connect to remote MCP server\"}, {\"name\": \"bridge_call_tool\", \"description\": \"Call tool on remote MCP server\"}, {\"name\": \"mcpb_build\", \"description\": \"Build MCPB bundle from tool sequence\"}, {\"name\": \"mcpb_inspect\", \"description\": \"Inspect MCPB bundle contents\"}]}"