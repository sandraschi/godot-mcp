{
  "$schema": "https://glama.ai/mcp/schema/2026",
  "name": "godot-mcp",
  "description": "AI-driven Godot 4.0 engine control via MCP tools. Import STL/GLB/OBJ geometry, load CFD velocity fields, spawn GPU particles, assign PBR materials, control cameras, animate characters, compose game scenes, and publish to itch.io and Steam.",
  "repository": "https://github.com/sandraschi/godot-mcp",
  "command": "uv",
  "args": ["run", "python", "-m", "godot_mcp.server"],
  "tools": [
    {"name": "godot_status", "description": "Query Godot engine version, node count, FPS"},
    {"name": "godot_import_stl", "description": "Import binary STL mesh as MeshInstance3D"},
    {"name": "godot_import_glb", "description": "Import GLB/GLTF model with hierarchy"},
    {"name": "godot_import_obj", "description": "Import Wavefront OBJ mesh"},
    {"name": "godot_load_velocity_field", "description": "Load CFD velocity field CSV"},
    {"name": "godot_spawn_particles", "description": "Create GPU particle system"},
    {"name": "godot_animate_streamlines", "description": "Animate particles along velocity field"},
    {"name": "godot_create_camera", "description": "Create Camera3D with orbit controls"},
    {"name": "godot_add_light", "description": "Add directional/ambient/omni light"},
    {"name": "godot_set_material", "description": "Assign PBR material to mesh node"},
    {"name": "godot_export_web", "description": "Export scene to HTML5/WebAssembly"},
    {"name": "godot_read_scene_tree", "description": "Dump scene hierarchy as JSON"},
    {"name": "godot_set_config", "description": "Write project.godot config"},
    {"name": "godot_headless_verify", "description": "Check headless mode availability"},
    {"name": "godot_play_animation", "description": "Play/list GLB animation clips"},
    {"name": "itch_status", "description": "Check Butler install and API key"},
    {"name": "godot_export_release", "description": "Export Godot project for itch.io"},
    {"name": "itch_push_preview", "description": "Preview Butler push diff"},
    {"name": "itch_push", "description": "Upload build via Butler"},
    {"name": "itch_latest_version", "description": "Query latest itch.io build"},
    {"name": "ship_to_itch", "description": "Export, preview and push to itch.io"},
    {"name": "steam_status", "description": "Check SteamPipe readiness"},
    {"name": "steam_checklist", "description": "Steam Direct release checklist"},
    {"name": "steam_monetization_guide", "description": "Steam pricing and revenue guide"},
    {"name": "steam_stage_build", "description": "Stage Windows build for Steam"},
    {"name": "ship_to_steam_prerelease", "description": "Upload to Steam beta branch"},
    {"name": "ship_to_steam_release", "description": "Upload to Steam live branch"},
    {"name": "ship_to_steam", "description": "End-to-end Steam ship pipeline"},
    {"name": "design_game", "description": "Design game from natural language concept"},
    {"name": "generate_game_worlds", "description": "Generate Marble worlds for game"},
    {"name": "compose_game_scene", "description": "Assemble Godot scene from game plan"},
    {"name": "generate_game_logic", "description": "Generate GDScript for game"},
    {"name": "export_and_ship", "description": "Export game and publish to itch.io"},
    {"name": "build_game", "description": "End-to-end game build pipeline"},
    {"name": "fleet_exchange_status", "description": "Fleet exchange depot status"},
    {"name": "fleet_import_from_exchange", "description": "Import model from fleet exchange"},
    {"name": "fleet_worldlabs_get_world", "description": "Fetch Marble world assets"},
    {"name": "fleet_worldlabs_stage_mesh", "description": "Stage Marble collider mesh"},
    {"name": "fleet_worldlabs_stage_splat", "description": "Stage Marble SPZ splat"},
    {"name": "fleet_worldlabs_import_mesh", "description": "Import Marble mesh into Godot"},
    {"name": "bridge_connect", "description": "Connect to remote MCP server"},
    {"name": "bridge_call_tool", "description": "Call tool on remote MCP server"},
    {"name": "artifact_list", "description": "List depot artifacts"},
    {"name": "artifact_search", "description": "Search depot artifacts"},
    {"name": "artifact_get", "description": "Get artifact details"},
    {"name": "artifact_register", "description": "Register new artifact"},
    {"name": "artifact_delete", "description": "Delete artifact"},
    {"name": "mcpb_build", "description": "Build MCPB bundle"},
    {"name": "mcpb_inspect", "description": "Inspect MCPB bundle contents"},
    {"name": "prefab_list", "description": "List prefab templates"},
    {"name": "prefab_apply", "description": "Apply prefab template"},
    {"name": "prompt_list", "description": "List prompt templates"},
    {"name": "prompt_execute", "description": "Execute prompt template"},
    {"name": "ai_describe_artifact", "description": "AI description for artifact"},
    {"name": "ai_generate_gdscript", "description": "Generate GDScript from spec"},
    {"name": "cad_sampling", "description": "CAD reasoning via LLM sampling"},
    {"name": "workflow_list", "description": "List built-in workflows"},
    {"name": "workflow_run", "description": "Run built-in workflow"}
  ],
  "prompts": [
    {"name": "design_game", "description": "Plan game from natural language concept"}
  ]
}
