{
  "productName": "Godot MCP",
  "version": "0.4.0-beta.1",
  "identifier": "ai.fleet.godot-mcp",
  "build": {
    "frontendDist": "../webapp/dist",
    "devUrl": "http://localhost:10992",
"beforeDevCommand": "bun --cwd ../webapp run dev",
"beforeBuildCommand": "bun --cwd ../webapp run build"
  },
  "app": {
    "windows": [
      {
        "title": "Godot MCP",
        "label": "main",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/godot-mcp-backend.exe",
      "resources/.env.example"
    ],
    "targets": [
      "nsis"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "skip"
      },
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "process": {
      "all": true
    }
  }
}

