{
  "productName": "Godot MCP",
  "version": "0.2.1",
  "identifier": "ai.fleet.godot-mcp",
  "build": {
    "frontendDist": "../web_sota/dist",
    "devUrl": "http://localhost:10992",
    "beforeDevCommand": "npm --prefix ../web_sota run dev",
    "beforeBuildCommand": "npm --prefix ../web_sota run build"
  },
  "app": {
    "windows": [
      {
        "title": "Godot MCP",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/godot-mcp-backend"
    ],
    "targets": [
      "nsis"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "skip"
      },
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "process": {
      "all": true
    }
  }
}
